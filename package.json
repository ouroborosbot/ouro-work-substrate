{
  "name": "ouro-work-substrate",
  "version": "0.1.0",
  "private": true,
  "description": "Hosted Ouro work substrate services for agent-owned mail and vault accounts.",
  "license": "UNLICENSED",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run build && vitest run",
    "typecheck": "npm run build",
    "clean": "rm -rf packages/*/dist apps/*/dist coverage"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.15.3",
    "@types/smtp-server": "^3.5.13",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  }
}
